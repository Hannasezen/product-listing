# Internal API (server-to-server, no BFF — see TECHNICAL.md)
API_URL=http://localhost:3001

# Database (Neon dev branch) — needed here too because the Auth.js DrizzleAdapter
# runs inside Next.js's Node-runtime route handler, not just NestJS
DATABASE_URL=

# Auth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
# Sender address for magic-link emails. Use onboarding@resend.dev for local
# dev (works with no domain verification); switch to a verified domain address
# in staging/production.
EMAIL_FROM=onboarding@resend.dev
ADMIN_EMAILS=

# Observability
HONEYCOMB_API_KEY=

# Analytics
POSTHOG_API_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
